{
  "expo": {
    "name": "animo-quorum",
    "slug": "animo-quorum",
    "main": "index.ts",
    "android": {
      "softwareKeyboardLayoutMode": "adjustResize",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-secure-store"
    ],
    "splash": {
      "image": "./assets/images/logoCrop.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532D"
    }
  }
}